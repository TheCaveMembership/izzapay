# --- TOKEN SETTINGS ---
ASSET_CODE=89
MINT_AMOUNT=1000000000.0000000
HOME_DOMAIN=izzapay.onrender.com

# Optional funding account (only needed if issuer/distributor not funded)
FUNDING_SECRET=
FUNDING_STARTING_BALANCE=5

# Optional base fee override (can leave blank)
BASE_FEE=

# --- RUNTIME SWITCHES ---
RUN_MINT=1          # ✅ we want to mint 1B 89 now
RUN_SELL_LADDER=1   # ✅ we want to post the ladder with the full 1B
RUN_AIRDROP=0
RUN_MOVE_IZZA=0
RUN_NATIVE_PAYOUT=0

# --- AIRDROP (ignored because RUN_AIRDROP=0) ---
AIRDROP_AMOUNT=0.0000001
AIRDROP_TAG=89DROP
AIRDROP_SINGLE_DEST=
AIRDROP_SLEEP_SECONDS=0.9
AIRDROP_MAX_RETRIES=3

# --- MOVE TOKEN (ignored because RUN_MOVE_IZZA=0) ---
MOVE_IZZA_DEST=
MOVE_IZZA_AMOUNT=0

# --- NATIVE TEST PI PAYOUT (ignored because RUN_NATIVE_PAYOUT=0) ---
NATIVE_PAYOUT_DEST=
NATIVE_PAYOUT_AMOUNT=0
NATIVE_PAYOUT_MEMO=89 test payout

# --- LADDER CONFIG: use FULL 1B supply, geometric, 0.0089 -> 89 ---
LADDER_MODE=geometric       # <- NOT "hype" so it uses LADDER_* instead
LADDER_START_PRICE=0.0089
LADDER_END_PRICE=89.0

# Use big chunks so we don’t create insane amounts of offers
# 1,000,000,000 / 2,500,000 = 400 rungs
LADDER_CHUNK=2500000
LADDER_TOTAL=1000000000

# Hype ladder settings are ignored when LADDER_MODE != hype, but can stay
HYPE_LADDER_TOTAL=25000
HYPE_LADDER_MIN_CHUNK=50
HYPE_LADDER_MAX_CHUNK=300
HYPE_LADDER_WIGGLE=0.04
