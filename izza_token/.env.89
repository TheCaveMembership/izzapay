RUN_SELL_LADDER=0     # set to 1 to post 89 sell offers
RUN_MOVE_IZZA=0       # still named "IZZA" in code, but works for any ASSET_CODE
RUN_NATIVE_PAYOUT=0
RUN_AIRDROP=0         # set to 1 if you want the airdrop logic to run for 89

# --- AIRDROP CONFIG (only matters if RUN_AIRDROP=1) ---
AIRDROP_AMOUNT=0.0000001
AIRDROP_TAG=89DROP
AIRDROP_SINGLE_DEST=
AIRDROP_SLEEP_SECONDS=0.9
AIRDROP_MAX_RETRIES=3

# --- MOVE TOKEN CONFIG (distributor -> some wallet) ---
